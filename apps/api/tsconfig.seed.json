{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolvePackageJsonExports": false,
    "isolatedModules": false,
    "strictNullChecks": true
  },
  "include": ["prisma/seed.ts"]
}
